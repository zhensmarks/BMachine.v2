<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:BMachine.UI.Views"
        xmlns:vm="using:BMachine.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="BMachine.App.Views.MainWindow"
        x:DataType="local:MainWindowViewModel"
        xmlns:local="using:BMachine.App.ViewModels"
        Title="BMachine v2"
        Icon="avares://BMachine.App/appicon.ico"
        Width="1280" Height="800"
        MinWidth="520"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="40"
        SystemDecorations="Full"
        UseLayoutRounding="True"
        Background="{Binding WindowBackground}">

    <Grid Name="MainRoot" RenderTransformOrigin="0.5,0.5">

        <!-- Exit Confirmation Overlay (ZIndex 999) - Suspended Glass & Outlined Buttons -->
        <Grid ZIndex="999" IsVisible="{Binding IsExitConfirmOpen}">
            
            <!-- Global Industrial Overlay (Full Window) -->
            <Border Background="#E6000000" CornerRadius="0" IsHitTestVisible="True"/>
            
            <!-- Logout Display (Industrial Terminal Style) -->
            <Border Width="420" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="#000000" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="0">
                
                <Grid RowDefinitions="Auto, *">
                    <!-- Top Accent Header (Like Splash Screen) -->
                    <Grid Grid.Row="0" Margin="15,10">
                        <TextBlock Text="TERMINAL // ACTION: LOGOUT" 
                                   Foreground="#475569" FontSize="9" FontFamily="Consolas, Courier New, monospace"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="ID: BMACHINE.SYS" 
                                   Foreground="#475569" FontSize="9" FontFamily="Consolas, Courier New, monospace"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Spacing="0" Margin="0,20,0,30">
                        <!-- Power Icon (Redesigned Sharp) -->
                        <Border Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,20"
                                Background="#000000" BorderBrush="#ef4444" BorderThickness="1" CornerRadius="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#ef4444" BlurRadius="15" Opacity="0.3"/>
                            </Border.Effect>
                            <PathIcon Data="M18.36 6.64a9 9 0 1 1-12.73 0M12 2v10" 
                                      Foreground="#ef4444" Width="20" Height="20" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="SYSTEM LOGOUT" FontWeight="Heavy" FontSize="20" 
                                   HorizontalAlignment="Center" LetterSpacing="2" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" 
                                   FontFamily="Consolas, Courier New, monospace"
                                   Margin="0,0,0,10"/>
                        
                        <!-- Body Text -->
                        <TextBlock Text="Are you sure you want to terminate the current session?" 
                                   TextAlignment="Center" Foreground="#94A3B8" 
                                   FontSize="13" Margin="40,0,40,30" TextWrapping="Wrap"
                                   FontFamily="Consolas, Courier New, monospace"/>
                        
                        <!-- Action Buttons (INDUSTRIAL SHARP) -->
                        <StackPanel Spacing="10" Margin="40,0">
                            <Grid ColumnDefinitions="*,10,*">
                                <!-- CANCEL (Industrial Sharp Gray) -->
                                <Button Grid.Column="0" Command="{Binding CancelExitCommand}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Background="Transparent" Foreground="#F8FAFC"
                                        BorderBrush="#475569" BorderThickness="1" 
                                        CornerRadius="0" Height="38" Cursor="Hand" Classes="Clear">
                                    <TextBlock Text="CANCEL" FontWeight="Bold" FontSize="13" LetterSpacing="1"
                                               FontFamily="Consolas, Courier New, monospace"/>
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="#1E293B"/>
                                            <Setter Property="BorderBrush" Value="#94A3B8"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>

                                <!-- LOGOUT (Industrial Sharp Red) -->
                                <Button Grid.Column="2" Command="{Binding ConfirmExitCommand}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Background="Transparent" Foreground="#ef4444"
                                        BorderBrush="#ef4444" BorderThickness="1" 
                                        CornerRadius="0" Height="38" Cursor="Hand" Classes="Clear">
                                    <TextBlock Text="LOGOUT" FontWeight="Bold" FontSize="13" LetterSpacing="1"
                                               FontFamily="Consolas, Courier New, monospace"/>
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="#ef4444"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </Grid>

                            <!-- REBOOT SYSTEM (Optional / Large Button) -->
                            <Button Command="{Binding RestartApplicationCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Background="Transparent" Foreground="#38BDF8"
                                    BorderBrush="#38BDF8" BorderThickness="1" 
                                    CornerRadius="0" Height="38" Cursor="Hand" Classes="Clear" Margin="0,5,0,0">
                                <TextBlock Text="REBOOT SYSTEM" FontWeight="Bold" FontSize="11" LetterSpacing="1.5"
                                           FontFamily="Consolas, Courier New, monospace"/>
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#38BDF8"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading overlay (shown while Dashboard is created after splash) -->
        <Grid IsVisible="{Binding IsLoadingDashboard}" Background="{Binding WindowBackground}" ZIndex="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Memuat Dashboard..." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
            </StackPanel>
        </Grid>

        <!-- Main Content (Fills Window) -->
        <ContentControl Content="{Binding CurrentView}" Margin="0">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:EditingCardListViewModel}">
                    <views:EditingCardListView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:RevisionCardListViewModel}">
                    <views:RevisionCardListView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:LateCardListViewModel}">
                    <views:LateCardListView/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>

</Window>
