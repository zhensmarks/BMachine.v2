<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BMachine.UI.ViewModels"
             xmlns:models="using:BMachine.UI.Models"
             xmlns:controls="using:BMachine.UI.Controls"
             xmlns:views="using:BMachine.UI.Views"
             x:Class="BMachine.UI.Views.RevisionCardListView"
             x:DataType="vm:RevisionCardListViewModel"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid x:Name="Part_RootGrid" Background="{DynamicResource AppBackgroundBrush}" SizeChanged="OnRootGridSizeChanged">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Main Content -->
        <Grid x:Name="Part_MainContent" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header (Removed for Unified Tab View) -->
            
            <!-- Cards List -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Cards}"
                     Margin="10,0,10,20"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerTheme>
                            <ControlTheme TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </ControlTheme>
                        </ListBox.ItemContainerTheme>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:TrelloCard">
                                <Button Command="{Binding $parent[UserControl].DataContext.SelectCardCommand}" 
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        Padding="0" BorderThickness="0" Background="Transparent"
                                        Margin="0,0,0,4" CornerRadius="0">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                    </Button.Styles>
                                    
                                    <Border ClipToBounds="True" CornerRadius="0" 
                                            BorderThickness="1"
                                            Classes.selected="{Binding IsActive}"
                                            DragDrop.AllowDrop="True" DragDrop.DragOver="OnCardDragOver" DragDrop.Drop="OnCardDrop">
                                        <Border.Styles>
                                            <Style Selector="Border.selected">
                                                <Setter Property="Background" Value="{DynamicResource AccentRevisionLowOpacityBrush}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
                                            </Style>
                                            <Style Selector="Border">
                                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                            </Style>
                                            <Style Selector="Border">
                                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                            </Style>
                                        </Border.Styles>
                                        
                                        <Grid RowDefinitions="Auto, *">
                                            <!-- Cover Overlay Background -->
                                            <Border Grid.RowSpan="2" CornerRadius="0" ClipToBounds="True"
                                                    IsVisible="{Binding HasCover}" Opacity="0.15">
                                                <Panel>
                                                    <Border Background="{Binding CoverColor}" IsVisible="{Binding !IsCoverImage}"/>
                                                    <Border Background="{Binding CoverColor}"/>
                                                </Panel>
                                            </Border>

                                            <!-- Content Grid -->
                                            <Grid Grid.Row="1" ColumnDefinitions="4, Auto, Auto, *, Auto" MinHeight="50" Margin="0,4">
                                            <!-- Accent Line (Left) -->
                                            <Border Grid.Column="0" Background="{DynamicResource AccentRevisionBrush}" 
                                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                    IsVisible="{Binding !IsActive}"/>
                                                    
                                            <!-- Drag Handle -->
                                            <PathIcon Grid.Column="1" Data="{StaticResource IconMenu}" Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"
                                                      Margin="10,0,0,0" VerticalAlignment="Center" Cursor="SizeAll"
                                                      ToolTip.Tip="Drag to Reorder"
                                                      PointerPressed="OnCardPointerPressed"/>
                                            
                                            <!-- Checkbox -->
                                            <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Margin="10,0,0,0" VerticalAlignment="Center"
                                                      Command="{Binding $parent[UserControl].DataContext.SelectionChangedCommand}"/>
                                            
                                            <!-- Name & Footer Actions -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,6" Spacing="4">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="SemiBold" FontSize="14" 
                                                           Foreground="{DynamicResource TextPrimaryBrush}" 
                                                           TextWrapping="Wrap" MaxLines="2"
                                                           TextTrimming="CharacterEllipsis"/>


                                            </StackPanel>
                                            
                                            <!-- Status Badges (Right Side) -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0" Spacing="6">
                                                
                                                <!-- Checklist Progress (Modern Badge) -->
                                                <Border CornerRadius="0" Padding="4,2" Margin="0,0,10,0" VerticalAlignment="Center"
                                                        IsVisible="{Binding HasChecklist}"
                                                        Background="#1A1A1A"
                                                        ToolTip.Tip="{Binding ChecklistTooltip}">
                                                 <Border.Styles>
                                                     <Style Selector="Border.valid">
                                                         <!-- Keep same background but icon will be green -->
                                                     </Style>
                                                 </Border.Styles>
                                                 <Classes.valid>
                                                     <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                         <Binding Path="HasEditingChecklist"/>
                                                     </MultiBinding>
                                                 </Classes.valid>
                                                 
                                                  <PathIcon Width="12" Height="12" Data="{StaticResource IconChecklistBadge}">
                                                      <PathIcon.Styles>
                                                          <Style Selector="PathIcon">
                                                              <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                              <Setter Property="Opacity" Value="0.5"/>
                                                          </Style>
                                                          <Style Selector="Border.valid PathIcon">
                                                              <Setter Property="Foreground" Value="#22C55E"/>
                                                              <Setter Property="Opacity" Value="1.0"/>
                                                          </Style>
                                                      </PathIcon.Styles>
                                                  </PathIcon>
                                             </Border>


                                            </StackPanel>

                                        </Grid> <!-- End Content Grid -->
                                        </Grid> <!-- End Row Grid -->
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
            </ListBox>

            <!-- FAB Refresh Button Removed -->
        </Grid>

        <views:CardDetailPanelHost Grid.Column="1" IsVisible="{Binding !IsPanelHostedExternally}"/>
    </Grid>
</UserControl>
