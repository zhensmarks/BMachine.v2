<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:BMachine.UI.ViewModels"
        xmlns:models="using:BMachine.UI.Models"
        xmlns:controls="using:BMachine.UI.Controls"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
        x:Class="BMachine.UI.Views.RadialMenuWindow"
        x:DataType="vm:RadialMenuViewModel"
        x:Name="RadialRoot"
        Width="200" Height="200"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        Title="RadialMenu">

    <Window.Styles>
        <!-- Item Button Style -->
        <Style Selector="Button.MenuButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <Border Name="PART_Bg"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Background="{TemplateBinding Background}" 
                                BorderBrush="#20FFFFFF"
                                BorderThickness="1">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        
                        <ContentPresenter Name="PART_Content"
                                          Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        
        <Style Selector="Button.MenuButton:pointerover /template/ Border#PART_Bg">
             <Setter Property="Background" Value="#55FFFFFF"/>
             <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.MenuButton.highlighted /template/ Border#PART_Bg">
             <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
             <Setter Property="BorderBrush" Value="White"/>
        </Style>

        <!-- Navigation Button (More/Back) -->
        <Style Selector="Button.NavButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="Button.NavButton:pointerover">
             <Setter Property="Background" Value="#44FFFFFF"/>
             <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>

    <Border Background="Transparent">
        <Grid>
             <!-- Ring area removed — fully transparent -->

             <!-- Pie Wedge Highlight -->
             <controls:PieWedge Width="200" Height="200"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                StartAngle="{Binding WedgeStart}"
                                SweepAngle="{Binding WedgeSweep}"
                                InnerRadius="18"
                                OuterRadius="72"
                                Fill="#303b82f6"
                                IsVisible="{Binding IsWedgeVisible}"/>

             <!-- Inner Ring (decorative) -->
             <Border Width="36" Height="36" CornerRadius="18" 
                     BorderBrush="#15FFFFFF" BorderThickness="1"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>

             <!-- Items on Canvas -->
             <ItemsControl ItemsSource="{Binding VisibleItems}" ClipToBounds="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="200" Height="200" ClipToBounds="False"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Styles>
                    <Style Selector="ItemsControl > ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:RadialMenuItem">
                        <Grid Width="32" Height="32" ClipToBounds="False">
                            <!-- Regular script button -->
                            <Button Classes="MenuButton" 
                                    Classes.highlighted="{Binding IsHighlighted}"
                                    IsVisible="{Binding !IsNavigation}"
                                    Command="{Binding DataContext.ExecuteScript, ElementName=RadialRoot}" 
                                    CommandParameter="{Binding ScriptPath}">
                                <Grid>
                                    <!-- Icon -->
                                    <Viewbox Width="16" Height="16" IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}">
                                         <Path Data="{Binding Icon}" Fill="{DynamicResource TextPrimaryBrush}" Stretch="Uniform"/>
                                    </Viewbox>
                                    
                                    <!-- Fallback Text -->
                                    <TextBlock Text="{Binding ShortName}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="8"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}"/>
                                </Grid>
                            </Button>

                            <!-- Navigation button (More / Back) -->
                            <Button Classes="NavButton"
                                    IsVisible="{Binding IsNavigation}"
                                    IsHitTestVisible="False">
                                <TextBlock Text="{Binding ShortName}" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
             </ItemsControl>

             <!-- Hover Label (positioned further out to avoid overlapping icons) -->
             <Canvas Width="200" Height="200" ClipToBounds="False" IsHitTestVisible="False"
                     IsVisible="{Binding IsWedgeVisible}">
                 <Border Canvas.Left="{Binding HighlightLabelX}" 
                         Canvas.Top="{Binding HighlightLabelY}"
                         Background="{DynamicResource CardBackgroundBrush}"
                         BorderBrush="#30FFFFFF" BorderThickness="1"
                         CornerRadius="10" Padding="8,3"
                         BoxShadow="0 2 8 0 #40000000"
                         Margin="-40,-12,0,0"
                         MaxWidth="120">
                     <TextBlock Text="{Binding HighlightLabel}" 
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                FontSize="10" FontWeight="SemiBold"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                MaxLines="2"/>
                 </Border>
             </Canvas>
        </Grid>
    </Border>
</Window>
