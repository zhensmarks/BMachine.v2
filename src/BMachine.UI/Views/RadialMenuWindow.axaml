<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:BMachine.UI.ViewModels"
        xmlns:models="using:BMachine.UI.Models"
        xmlns:controls="using:BMachine.UI.Controls"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
        x:Class="BMachine.UI.Views.RadialMenuWindow"
        x:DataType="vm:RadialMenuViewModel"
        x:Name="RadialRoot"
        Width="200" Height="200"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        Title="RadialMenu">

    <Window.Styles>
        <!-- Item Button Style -->
        <Style Selector="Button.MenuButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <Border Name="PART_Bg"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        <ContentPresenter Name="PART_Content"
                                          Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        
        <Style Selector="Button.MenuButton:pointerover">
             <Setter Property="Cursor" Value="Hand"/>
             <Setter Property="RenderTransform" Value="scale(1.15)"/>
        </Style>

        <!-- Restore accent highlight effect: handled by the PieWedge slice instead -->
        <Style Selector="Button.MenuButton.highlighted /template/ Border#PART_Bg">
             <!-- Empty, let the PieWedge handle the glow beneath it -->
        </Style>

        <!-- Navigation Button (More/Back) -->
        <Style Selector="Button.NavButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="Button.NavButton:pointerover">
             <Setter Property="Background" Value="#44FFFFFF"/>
             <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>

    <Border Background="Transparent">
        <Grid>
             <!-- 1. Main Background Plate (Donut Shape / Bolong Tengah) -->
             <Border Width="140" Height="140" CornerRadius="70"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     BorderBrush="#40FFFFFF" BorderThickness="1"
                     Background="Transparent">
                  <Ellipse Width="85" Height="85"
                           Stroke="{DynamicResource AppBackgroundBrush}"
                           StrokeThickness="55" Opacity="0.6"/>
             </Border>

             <!-- 2. Segmented Divider Lines -->
             <Canvas Width="140" Height="140" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                 <!-- N -->
                 <Line StartPoint="70,0" EndPoint="70,55" Stroke="#10FFFFFF" StrokeThickness="1"/>
                 <!-- S -->
                 <Line StartPoint="70,85" EndPoint="70,140" Stroke="#10FFFFFF" StrokeThickness="1"/>
                 <!-- W -->
                 <Line StartPoint="0,70" EndPoint="55,70" Stroke="#10FFFFFF" StrokeThickness="1"/>
                 <!-- E -->
                 <Line StartPoint="85,70" EndPoint="140,70" Stroke="#10FFFFFF" StrokeThickness="1"/>
                 <!-- NW -->
                 <Line StartPoint="20.5,20.5" EndPoint="59.4,59.4" Stroke="#10FFFFFF" StrokeThickness="1"/>
                 <!-- SE -->
                 <Line StartPoint="80.6,80.6" EndPoint="119.5,119.5" Stroke="#10FFFFFF" StrokeThickness="1"/>
                 <!-- NE -->
                 <Line StartPoint="119.5,20.5" EndPoint="80.6,59.4" Stroke="#10FFFFFF" StrokeThickness="1"/>
                 <!-- SW -->
                 <Line StartPoint="20.5,119.5" EndPoint="59.4,80.6" Stroke="#10FFFFFF" StrokeThickness="1"/>
             </Canvas>

             <!-- Hover Pie Wedge (Pizza Slice Highlight) -->
             <controls:PieWedge Width="140" Height="140"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                StartAngle="{Binding WedgeStartAngle}" SweepAngle="{Binding WedgeSweepAngle}"
                                InnerRadius="15" OuterRadius="70"
                                Fill="{DynamicResource AccentBlueBrush}" Opacity="0.6"
                                IsVisible="{Binding IsHighlighted, FallbackValue=False}"
                                IsHitTestVisible="False"/>

             <!-- 4. Planet Orbit Ring (Inner Divider) -->
             <Border Width="70" Height="70" CornerRadius="35"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     BorderBrush="#15FFFFFF" BorderThickness="1.5"
                     Background="Transparent" IsHitTestVisible="False"/>

             <!-- 5. Blank Central Hub (Bolong/Transparent) -->
             <Border Width="30" Height="30" CornerRadius="15" 
                     BorderBrush="#25FFFFFF" BorderThickness="1.5"
                     Background="Transparent"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>

             <!-- 6. Items on Canvas -->
             <ItemsControl ItemsSource="{Binding VisibleItems}" ClipToBounds="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="200" Height="200" ClipToBounds="False"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Styles>
                    <Style Selector="ItemsControl > ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:RadialMenuItem">
                        <Grid Width="36" Height="36" ClipToBounds="False">
                            <!-- Regular script button -->
                            <Button Classes="MenuButton" 
                                    Classes.highlighted="{Binding IsHighlighted}"
                                    IsVisible="{Binding !IsNavigation}"
                                    Command="{Binding DataContext.ExecuteScript, ElementName=RadialRoot}" 
                                    CommandParameter="{Binding ScriptPath}">
                                <Grid>
                                    <!-- Icon with Drop Shadow for legibility -->
                                    <Viewbox Width="18" Height="18" IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}">
                                         <Path Data="{Binding Icon}" Fill="{DynamicResource TextPrimaryBrush}" Stretch="Uniform">
                                             <Path.Effect>
                                                 <DropShadowEffect BlurRadius="4" Opacity="0.5" OffsetX="0" OffsetY="2" Color="Black"/>
                                             </Path.Effect>
                                         </Path>
                                    </Viewbox>
                                    
                                    <!-- Fallback Text -->
                                    <TextBlock Text="{Binding ShortName}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}">
                                         <TextBlock.Effect>
                                             <DropShadowEffect BlurRadius="4" Opacity="0.5" OffsetX="0" OffsetY="2" Color="Black"/>
                                         </TextBlock.Effect>
                                    </TextBlock>
                                </Grid>
                            </Button>

                            <!-- Navigation button (More / Back) -->
                            <Button Classes="NavButton"
                                    IsVisible="{Binding IsNavigation}"
                                    IsHitTestVisible="False">
                                <TextBlock Text="{Binding ShortName}" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
             </ItemsControl>

             <!-- Hover Label (positioned further out to avoid overlapping icons) -->
             <Canvas Width="200" Height="200" ClipToBounds="False" IsHitTestVisible="False"
                     IsVisible="{Binding IsWedgeVisible}">
                 <Border Canvas.Left="{Binding HighlightLabelX}" 
                         Canvas.Top="{Binding HighlightLabelY}"
                         Background="{DynamicResource CardBackgroundBrush}"
                         BorderBrush="#30FFFFFF" BorderThickness="1"
                         CornerRadius="10" Padding="8,3"
                         BoxShadow="0 2 8 0 #40000000"
                         Margin="-40,-12,0,0"
                         MaxWidth="120">
                     <TextBlock Text="{Binding HighlightLabel}" 
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                FontSize="10" FontWeight="SemiBold"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                MaxLines="2"/>
                 </Border>
             </Canvas>
        </Grid>
    </Border>
</Window>
