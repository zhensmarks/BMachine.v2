<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BMachine.UI.ViewModels"
             xmlns:models="using:BMachine.UI.Models"
             xmlns:controls="using:BMachine.UI.Controls"
             x:Class="BMachine.UI.Views.CardDetailPanelHost"
             x:DataType="vm:BaseTrelloListViewModel">
    <Grid>
        <!-- Side Panel: Card Details -->
        <Border x:Name="Part_DetailPanel" Width="400" Background="{DynamicResource BackgroundDarkBrush}"
                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1,0,0,0"
                IsVisible="{Binding IsDetailPanelOpen}"
                PointerPressed="OnDetailPanelPointerPressed">
            <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="{Binding SelectedCard.CoverDisplayName}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               IsVisible="{Binding SelectedCard.HasCoverDisplayName}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedCard.EventDateText}" FontWeight="SemiBold" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding SelectedCard.HasEventDate}"/>
                                </Grid>
                                <TextBlock Text="{Binding SelectedCard.Name}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding $parent[UserControl].DataContext.CloseDetailPanelCommand}" Content="✕"
                                    Background="Transparent" BorderThickness="0" FontSize="14"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Cursor="Hand" VerticalAlignment="Top" Padding="6,2" CornerRadius="4">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>

                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Button Classes="Clear" Padding="0" Background="Transparent" VerticalAlignment="Center" Margin="0,0,4,4"
                                    Command="{Binding $parent[UserControl].DataContext.CopyIdCommand}" CommandParameter="{Binding SelectedCard.DisplayId}"
                                    IsVisible="{Binding SelectedCard.HasDisplayId}" Cursor="Hand" ToolTip.Tip="Click to Copy ID">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Style>
                                </Button.Styles>
                                <Border Background="{Binding AccentColor}" CornerRadius="4" Height="24" Padding="8,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="ID:" FontSize="10" FontWeight="Bold" Foreground="White" Opacity="0.8"/>
                                        <TextBlock Text="{Binding SelectedCard.DisplayId}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Classes="Clear" Padding="0" Background="Transparent" VerticalAlignment="Center" Margin="0,0,4,4"
                                    Command="{Binding $parent[UserControl].DataContext.ShowAttachmentsCommand}" CommandParameter="{Binding SelectedCard}"
                                    IsVisible="{Binding SelectedCard.HasAttachments}" Cursor="Hand" ToolTip.Tip="View Attachments">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Style>
                                </Button.Styles>
                                <Border Background="#555555" CornerRadius="4" Height="24" Padding="8,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <PathIcon Data="{StaticResource IconPaperclip}" Width="11" Height="11" Foreground="White"/>
                                        <TextBlock Text="{Binding SelectedCard.AttachmentCount}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Border Background="#555555" CornerRadius="4" Height="24" Padding="8,0" Margin="0,0,4,4" VerticalAlignment="Center"
                                    IsVisible="{Binding SelectedCard.DueDateText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <PathIcon Data="{StaticResource IconClock}" Width="11" Height="11" Foreground="White"/>
                                    <TextBlock Text="{Binding SelectedCard.DueDateText}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding SelectedCard.Labels}" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding ColorHex}" CornerRadius="4" Height="24" Padding="8,0" Margin="0,0,4,4">
                                            <TextBlock Text="{Binding Name}" Foreground="{Binding TextColorHex}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>

                        <Border Height="1" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.3" Margin="0"/>

                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0">
                            <Button Command="{Binding $parent[UserControl].DataContext.ShowCommentsCommand}" CommandParameter="{Binding SelectedCard}"
                                    Classes="Clear" Padding="0" Background="Transparent" ToolTip.Tip="Comments">
                                <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="Transparent"/></Style></Button.Styles>
                                <Border Background="{Binding AccentColor}" CornerRadius="4" Height="28" Padding="12,0">
                                    <TextBlock Text="Comment" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </Border>
                            </Button>
                            <Button Command="{Binding $parent[UserControl].DataContext.ShowChecklistsCommand}" CommandParameter="{Binding SelectedCard}"
                                    Classes="Clear" Padding="0" Background="Transparent" ToolTip.Tip="Checklists">
                                <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="Transparent"/></Style></Button.Styles>
                                <Border Background="{Binding AccentColor}" CornerRadius="4" Height="28" Padding="12,0">
                                    <TextBlock Text="Checklist" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </Border>
                            </Button>
                            <Button Command="{Binding $parent[UserControl].DataContext.StartMoveCardCommand}" CommandParameter="{Binding SelectedCard}"
                                    Classes="Clear" Padding="0" Background="Transparent"
                                    IsEnabled="{Binding IsOnline}" IsVisible="{Binding !SelectedCard.IsManual}" ToolTip.Tip="Move Card">
                                <Button.Styles><Style Selector="Button:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="Transparent"/></Style></Button.Styles>
                                <Border Background="{Binding AccentColor}" CornerRadius="4" Height="28" Padding="12,0">
                                    <TextBlock Text="Move" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </Border>
                            </Button>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource TextSecondaryBrush}" Opacity="0.3" Margin="0"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Description" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <SelectableTextBlock Text="{Binding SelectedCard.Description}"
                                                 TextWrapping="Wrap"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Padding="0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Side Panel: Comments -->
        <Border x:Name="Part_CommentPanel" Width="350" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1,0,0,0"
                IsVisible="{Binding IsCommentPanelOpen}"
                PointerPressed="OnSubPanelPointerPressed">
            <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Comments" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedCard.Name}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Click="OnOpenCommentWindowClicked"
                                Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand" ToolTip.Tip="Open in New Window">
                            <PathIcon Data="{StaticResource IconOpenWindow}" Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Command="{Binding $parent[UserControl].DataContext.CloseCommentsPanelCommand}" Content="✕"
                                Background="Transparent" BorderThickness="0" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer x:Name="Part_CommentScrollViewer" Grid.Row="1">
                    <StackPanel Spacing="15">
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingComments}" Margin="0,20"/>
                        <TextBlock Text="No comments yet." IsVisible="{Binding !Comments.Count}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontStyle="Italic" HorizontalAlignment="Center"/>

                        <ItemsControl ItemsSource="{Binding Comments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                        <Grid RowDefinitions="Auto, *">
                                            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding MemberCreatorName}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:dd MMM HH:mm}'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,1,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" IsVisible="{Binding IsMine}">
                                                    <Button Command="{Binding $parent[UserControl].DataContext.BeginEditCommentCommand}" CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand" ToolTip.Tip="Edit Comment"
                                                            IsVisible="{Binding !IsEditing}">
                                                        <PathIcon Data="{StaticResource IconEdit}" Width="12" Height="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </Button>
                                                    <Button Command="{Binding $parent[UserControl].DataContext.DeleteCommentCommand}" CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand" ToolTip.Tip="Delete Comment"
                                                            IsVisible="{Binding !IsEditing}">
                                                        <PathIcon Data="{StaticResource IconTrash}" Width="12" Height="12" Foreground="#ef4444"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="1">
                                                <controls:FormattedTextBlock Text="{Binding Text}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                                                                             IsVisible="{Binding !IsEditing}"/>

                                                <StackPanel IsVisible="{Binding IsEditing}" Spacing="6" Margin="0,4,0,0">
                                                    <TextBox Text="{Binding EditText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                                             Background="#1AFFFFFF" BorderBrush="{DynamicResource SeparatorBrush}" CornerRadius="6"
                                                             Padding="8" FontSize="13"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                                        <Button Content="Cancel" Command="{Binding $parent[UserControl].DataContext.CancelEditCommentCommand}" CommandParameter="{Binding}"
                                                                Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" Padding="12,6" CornerRadius="4" Cursor="Hand" FontSize="12"/>
                                                        <Button Content="Save" Command="{Binding $parent[UserControl].DataContext.SaveEditCommentCommand}" CommandParameter="{Binding}"
                                                                Background="{DynamicResource AccentColorBrush}" Foreground="White" Padding="12,6" CornerRadius="4" Cursor="Hand" FontSize="12" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,20,0,0">
                    <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                        <Border Background="#10FFFFFF" CornerRadius="8" Padding="8" Margin="0,0,0,8"
                                IsVisible="{Binding HasPendingAttachments}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Attachments" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <ItemsControl ItemsSource="{Binding PendingAttachments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:PendingAttachmentItem">
                                            <Border Background="#15FFFFFF" CornerRadius="6" Padding="4" Margin="0,0,6,6"
                                                    Width="70" Height="70" ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                           IsVisible="{Binding IsImage}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <StackPanel IsVisible="{Binding !IsImage}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                                                        <PathIcon Data="{StaticResource IconFile}" Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding FileName}" FontSize="8" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" MaxWidth="60"/>
                                                    </StackPanel>
                                                    <Button Command="{Binding $parent[UserControl].DataContext.RemoveAttachmentCommand}" CommandParameter="{Binding}"
                                                            Width="16" Height="16" CornerRadius="8" Padding="0"
                                                            Background="#CC000000" BorderThickness="0" Cursor="Hand"
                                                            HorizontalAlignment="Right" VerticalAlignment="Top">
                                                        <TextBlock Text="✕" FontSize="9" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="10" Margin="0,0,0,8"
                                IsVisible="{Binding IsPresetPanelOpen}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Quick Replies (Max 5)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>

                                <ItemsControl ItemsSource="{Binding CommentPresets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                                <Button Command="{Binding $parent[UserControl].DataContext.UsePresetCommand}" CommandParameter="{Binding}"
                                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                        Background="Transparent" BorderThickness="0" Padding="8,4" Cursor="Hand">
                                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </Button>
                                                <Button Grid.Column="1" Command="{Binding $parent[UserControl].DataContext.DeleteCommentPresetCommand}" CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                                                    <PathIcon Data="{StaticResource IconTrash}" Width="12" Height="12" Foreground="#ef4444"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding CommentPresets.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBox Text="{Binding NewPresetText}" Watermark="New preset... (Enter to save)"
                                             Background="#1AFFFFFF" BorderThickness="0" CornerRadius="4" Padding="6" Margin="0,0,4,0">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Enter" Command="{Binding $parent[UserControl].DataContext.AddCommentPresetCommand}"/>
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                    <Button Grid.Column="1" Command="{Binding $parent[UserControl].DataContext.AddCommentPresetCommand}"
                                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand" ToolTip.Tip="Save Preset">
                                        <PathIcon Data="{StaticResource IconCheck}" Width="14" Height="14" Foreground="#22C55E"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="6" Margin="0,0,0,4" MaxHeight="140"
                                IsVisible="{Binding IsMentionPopupOpen}">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding FilteredMembers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TrelloMember">
                                            <Button Command="{Binding $parent[UserControl].DataContext.SelectMentionCommand}" CommandParameter="{Binding}"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                    Background="Transparent" BorderThickness="0" Padding="6,4" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource AccentColorBrush}">
                                                        <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="White" FontWeight="Bold" FontSize="9"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" FontSize="11"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <TextBox x:Name="Part_CommentTextBox" Text="{Binding NewCommentText}" Watermark="Write a comment... (@mention)"
                                 Background="#1AFFFFFF" BorderThickness="0" CornerRadius="8" Padding="10"
                                 Margin="0,0,10,0" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding $parent[UserControl].DataContext.SendCommentCommand}"/>
                            </TextBox.KeyBindings>
                            <TextBox.InnerLeftContent>
                                <Button x:Name="Part_InlineAttachButton"
                                        Command="{Binding $parent[UserControl].DataContext.AddAttachmentCommand}"
                                        Background="Transparent" BorderThickness="0" Padding="8,0,0,0" Margin="0" Cursor="Hand"
                                        ToolTip.Tip="Attach Image">
                                    <PathIcon Data="{StaticResource IconPaperclip}" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Button>
                            </TextBox.InnerLeftContent>
                            <TextBox.InnerRightContent>
                                <Button Command="{Binding $parent[UserControl].DataContext.TogglePresetPanelCommand}"
                                        Width="30" Height="30" CornerRadius="15"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        ToolTip.Tip="Quick Replies">
                                    <PathIcon Data="{StaticResource IconChevronUp}" Width="12" Height="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Button>
                            </TextBox.InnerRightContent>
                        </TextBox>
                    </StackPanel>

                    <Button Grid.Column="1" Command="{Binding $parent[UserControl].DataContext.SendCommentCommand}"
                            Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AccentColorBrush}" Cursor="Hand" ToolTip.Tip="Send Comment" VerticalAlignment="Bottom" Margin="0,0,0,5">
                        <PathIcon Data="{StaticResource IconSend}" Foreground="White" Width="16" Height="16"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Side Panel: Checklist -->
        <Border x:Name="Part_ChecklistPanel" Width="400" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1,0,0,0"
                IsVisible="{Binding IsChecklistPanelOpen}"
                PointerPressed="OnSubPanelPointerPressed">
            <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Checklists" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedCard.Name}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding $parent[UserControl].DataContext.CloseChecklistPanelCommand}" Content="✕"
                            Background="Transparent" BorderThickness="0" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand"/>
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="20">
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingChecklists}" Margin="0,20"/>
                        <TextBlock Text="No checklists found." IsVisible="{Binding !Checklists.Count}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontStyle="Italic" HorizontalAlignment="Center"/>

                        <ItemsControl ItemsSource="{Binding Checklists}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="10" Margin="0,0,0,20">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <PathIcon Data="{StaticResource IconCheckSquare}"
                                                      Foreground="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                                            <Button Grid.Column="2"
                                                    Command="{Binding $parent[UserControl].DataContext.DeleteChecklistCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Padding="8,4" Cursor="Hand" ToolTip.Tip="Delete Checklist">
                                                <PathIcon Data="{StaticResource IconTrash}" Width="14" Height="14" Foreground="#ef4444"/>
                                            </Button>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Content="{Binding Name}" Margin="5,2"
                                                              Command="{Binding $parent[UserControl].DataContext.ToggleCheckItemCommand}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" CornerRadius="8" Padding="15" IsVisible="{Binding IsDuplicateMode}" Margin="0,0,0,10">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Duplicate Checklist" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <StackPanel Spacing="5">
                                <TextBlock Text="New Name:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding DuplicateChecklistName}" Watermark="#EDITING USER_PROFILE" IsReadOnly="True"/>
                            </StackPanel>
                            <StackPanel Spacing="5">
                                <TextBlock Text="Source:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <AutoCompleteBox ItemsSource="{Binding Checklists}"
                                                 SelectedItem="{Binding SelectedSourceChecklist}"
                                                 ValueMemberBinding="{Binding Name}"
                                                 Watermark="Select source..."
                                                 HorizontalAlignment="Stretch"
                                                 FilterMode="Contains"
                                                 MinimumPrefixLength="0"
                                                 MaxDropDownHeight="160"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                                <Button Grid.Column="0" Content="Cancel" Command="{Binding $parent[UserControl].DataContext.ToggleDuplicateModeCommand}"
                                        Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                                <Button Grid.Column="1" Content="Create Copy" Command="{Binding $parent[UserControl].DataContext.DuplicateChecklistCommand}"
                                        Classes="Primary" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Button Command="{Binding $parent[UserControl].DataContext.ToggleDuplicateModeCommand}"
                            IsVisible="{Binding !IsDuplicateMode}"
                            Classes="Primary" HorizontalAlignment="Center" FontSize="12" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource IconPlus}" Width="12" Height="12"/>
                            <TextBlock Text="Duplicate Checklist"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Side Panel: Move Card -->
        <Border x:Name="Part_MovePanel" Width="400" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1,0,0,0"
                IsVisible="{Binding IsMovePanelOpen}"
                PointerPressed="OnSubPanelPointerPressed">
            <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Move Card" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedCard.Name}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding $parent[UserControl].DataContext.CloseMovePanelCommand}" Content="✕"
                            Background="Transparent" BorderThickness="0" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand"/>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="20">
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingMoveData}" Margin="0,0,0,10"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Choose Board" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <AutoCompleteBox ItemsSource="{Binding AvailableBoards}"
                                         SelectedItem="{Binding SelectedMoveBoard}"
                                         ValueMemberBinding="{Binding Name}"
                                         Watermark="Search board..."
                                         HorizontalAlignment="Stretch"
                                         FilterMode="Contains"
                                         MinimumPrefixLength="0"
                                         MaxDropDownHeight="160"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Select List" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <AutoCompleteBox ItemsSource="{Binding AvailableLists}"
                                         SelectedItem="{Binding SelectedMoveList}"
                                         ValueMemberBinding="{Binding Name}"
                                         Watermark="Search list..."
                                         HorizontalAlignment="Stretch"
                                         FilterMode="Contains"
                                         MinimumPrefixLength="0"
                                         IsEnabled="{Binding SelectedMoveBoard, Converter={x:Static ObjectConverters.IsNotNull}}"
                                         MaxDropDownHeight="160"/>
                    </StackPanel>

                    <Button Command="{Binding $parent[UserControl].DataContext.MoveCardCommand}"
                            HorizontalAlignment="Stretch"
                            Classes="Primary" Margin="0,20,0,0"
                            IsEnabled="{Binding SelectedMoveList, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <TextBlock Text="Confirm Move" FontWeight="Bold"/>
                            <PathIcon Data="{StaticResource IconArrowRight}" Foreground="White" Width="12" Height="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Side Panel: Attachments -->
        <Border x:Name="Part_AttachmentPanel" Width="400" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1,0,0,0"
                IsVisible="{Binding IsAttachmentPanelOpen}"
                PointerPressed="OnSubPanelPointerPressed">
            <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Attachments" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedCard.Name}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding $parent[UserControl].DataContext.CloseAttachmentPanelCommand}" Content="✕"
                            Background="Transparent" BorderThickness="0" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand"/>
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="20">
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingAttachments}" Margin="0,20"/>
                        <TextBlock Text="No attachments." IsVisible="{Binding !Attachments.Count}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontStyle="Italic" HorizontalAlignment="Center"/>

                        <ItemsControl ItemsSource="{Binding Attachments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="160" ItemHeight="160"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="5" Background="#1AFFFFFF" CornerRadius="8" ClipToBounds="True">
                                        <Grid RowDefinitions="*, Auto">
                                            <Button Grid.Row="0" Command="{Binding $parent[UserControl].DataContext.OpenAttachmentCommand}" CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
                                                <Panel>
                                                    <Image Source="{Binding Thumbnail}" IsVisible="{Binding IsImage}" Stretch="UniformToFill"/>
                                                    <PathIcon IsVisible="{Binding !IsImage}" Data="{StaticResource IconFile}"
                                                              Foreground="{DynamicResource TextSecondaryBrush}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                                </Panel>
                                            </Button>

                                            <Button Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Right" Background="#AA000000" CornerRadius="4" Margin="5" Padding="4"
                                                    Command="{Binding $parent[UserControl].DataContext.DownloadAttachmentCommand}" CommandParameter="{Binding}"
                                                    ToolTip.Tip="Download File">
                                                <PathIcon Data="{StaticResource IconDownload}" Foreground="White" Width="12" Height="12"/>
                                            </Button>

                                            <Grid Grid.Row="0" Background="#66000000" IsVisible="{Binding IsDownloading}">
                                                <ProgressBar IsIndeterminate="True" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>

                                            <Border Grid.Row="1" Background="#CC000000" Padding="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Name}"/>
                                                    <TextBlock Text="{Binding Bytes}" Foreground="#BBB" FontSize="9"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
