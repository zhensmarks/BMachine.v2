<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:BMachine.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="350"
        x:Class="BMachine.UI.Views.SplashWindow"
        x:DataType="vm:SplashViewModel"
        Width="600" Height="350"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        Topmost="True">

    <Border CornerRadius="0" ClipToBounds="True" BorderBrush="#1E293B" BorderThickness="1" Background="#000000">
        <Grid>
            <!-- Decorative Terminal Accents -->
            <TextBlock Text="BMACHINE // TERMINAL BOOTSTRAPPER" 
                       Foreground="#64748B" FontSize="10" FontFamily="Consolas, Courier New, monospace"
                       Margin="15,10" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                       
            <TextBlock Text="SYS.INIT: TRUE" 
                       Foreground="#64748B" FontSize="10" FontFamily="Consolas, Courier New, monospace"
                       Margin="15,10" HorizontalAlignment="Right" VerticalAlignment="Top"/>

            <!-- 2. Main Content Container -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5" Margin="0,0,0,100">
                <!-- NEW LOGO IMAGE -->
                <Image Source="avares://BMachine.UI/Assets/splash_logo.png" 
                       Width="150" 
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapInterpolationMode="HighQuality">
                </Image>
                    
                <!-- Version -->
                <TextBlock Text="v2.0" 
                           FontSize="10" 
                           FontWeight="Bold"
                           FontFamily="Consolas, Courier New, monospace"
                           HorizontalAlignment="Center" 
                           Foreground="#475569" 
                           LetterSpacing="2"
                           Margin="0,-5,0,0"/>
            </StackPanel>

            <!-- 3. Footer: Terminal Console & Progress -->
            <StackPanel VerticalAlignment="Bottom" Margin="40,0,40,40" Spacing="10">
                
                <!-- Hacker Terminal Log Box -->
                <Border Background="#000000" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="0" Padding="12,10" Height="70">
                    <ItemsControl ItemsSource="{Binding TerminalLogs}" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                           FontSize="11" 
                                           FontFamily="Consolas, Courier New, monospace"
                                           Foreground="#38BDF8" 
                                           Opacity="0.9"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                           
                <!-- Progress Bar Container -->
                <Grid Height="3" Margin="0,5,0,0">
                    <!-- Track -->
                    <Border Background="#1E293B" CornerRadius="0"/>
                    
                    <!-- Styled Progress Bar with Smooth Transitions -->
                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="3" 
                                 Background="Transparent" Foreground="#38BDF8" 
                                 BorderThickness="0" CornerRadius="0"
                                 ShowProgressText="False">
                        <ProgressBar.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Value" Duration="0:0:0.3"/>
                            </Transitions>
                        </ProgressBar.Transitions>
                        <ProgressBar.Effect>
                            <DropShadowEffect Color="#38BDF8" BlurRadius="10" Opacity="0.5"/>
                        </ProgressBar.Effect>
                    </ProgressBar>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
