<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BMachine.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="BMachine.UI.Views.CompactPixelcutView"
             x:DataType="vm:PixelcutViewModel">

    <UserControl.Resources>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- 0. Header (Window Mode Only) -->
        <Grid Grid.Row="0" Height="40" Background="Transparent" 
              IsVisible="{Binding IsWindowMode, RelativeSource={RelativeSource AncestorType=UserControl}}"
              PointerPressed="OnHeaderPointerPressed">
            <TextBlock Text="Pixelcut" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold" FontSize="14" 
                       Foreground="{DynamicResource TextPrimaryBrush}" IsHitTestVisible="False"/>
            
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Click="OnCloseWindow"
                    Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="4" ToolTip.Tip="Close">
                <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                          Width="10" Height="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Button>
        </Grid>
        <!-- Main Content Area -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" 
                CornerRadius="20" Padding="0" ClipToBounds="True"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
            
            <Grid DragDrop.AllowDrop="True" Background="Transparent">
                <!-- Empty State (Drop Zone - Visual Only) -->
                <Grid IsVisible="{Binding !HasFiles}">
                    <Border Margin="20" Background="Transparent" CornerRadius="16" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                             <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="24"
                                     HorizontalAlignment="Center" Width="80" Height="64">
                                 <!-- Box Icon -->
                                 <PathIcon Data="M21 16.5C21 16.88 20.79 17.21 20.47 17.38L12.57 21.82C12.41 21.94 12.21 22 12 22C11.79 22 11.59 21.94 11.43 21.82L3.53 17.38C3.21 17.21 3 16.88 3 16.5V7.5C3 7.12 3.21 6.79 3.53 6.62L11.43 2.18C11.59 2.06 11.79 2 12 2C12.21 2 12.41 2.06 12.57 2.18L20.47 6.62C20.79 6.79 21 7.12 21 7.5V16.5M12 4.15L6.04 7.5L12 10.85L17.96 7.5L12 4.15M5 15.91L11 19.29V12.58L5 9.21V15.91M19 15.91V9.21L13 12.58V19.29L19 15.91Z" 
                                           Width="32" Height="32" Foreground="{DynamicResource TextSecondaryBrush}"/>
                             </Border>
                            <TextBlock Text="Drop Images Here (Folders Supported)" FontSize="15" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- File List (Compact) -->
                <!-- Use ListBox for AutoScroll capability -->
                <ListBox x:Name="FileListBox" IsVisible="{Binding HasFiles}" ItemsSource="{Binding Files}" Background="Transparent" 
                         Margin="10" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionMode="Multiple">
                    <ListBox.Styles>
                        <!-- Transparent Item Container -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Background="{TemplateBinding Background}"
                                                      BorderBrush="{TemplateBinding BorderBrush}"
                                                      BorderThickness="{TemplateBinding BorderThickness}"
                                                      CornerRadius="{TemplateBinding CornerRadius}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Content="{TemplateBinding Content}"
                                                      Padding="{TemplateBinding Padding}"
                                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                </ControlTemplate>
                            </Setter>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" CornerRadius="6" Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                    Margin="0,0,0,4"
                                    Cursor="Hand"
                                    PointerPressed="OnFileItemPointerPressed"> 
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <!-- 1. Checkbox -->
                                    <CheckBox IsChecked="{Binding IsSelected}" IsHitTestVisible="False"
                                              VerticalAlignment="Center" Margin="0,0,10,0" MinHeight="0" Padding="0"/>
                                    
                                    <!-- 2. Left: Name & Progress Bar -->
                                    <Grid Grid.Column="1" RowDefinitions="Auto, Auto" VerticalAlignment="Center">
                                        <!-- Name (Bold) -->
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="13" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,4"/>
                                                   
                                        <!-- Progress Bar (Blue Line Under Name) - Visible only if Processing -->
                                        <ProgressBar Grid.Row="1" Height="3" HorizontalAlignment="Stretch"
                                                     Foreground="{DynamicResource AccentBlueBrush}" Background="Transparent" BorderThickness="0"
                                                     Value="{Binding Progress}" Maximum="100" 
                                                     IsVisible="{Binding IsProcessing}"/>
                                                     
                                        <!-- Error Message (If Failed) - Replaces Progress Bar -->
                                        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" FontSize="10" FontWeight="Bold" Foreground="#EF4444" 
                                                   IsVisible="{Binding IsFailed}" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                    
                                    <!-- 3. Right: Size & Status -->
                                    <StackPanel Grid.Column="2" Margin="15,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <!-- Sizes Line -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                            <!-- Original Size -->
                                            <TextBlock Text="{Binding OriginalSizeDisplay}" FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}" 
                                                       VerticalAlignment="Center" TextTrimming="None" TextWrapping="NoWrap"/>
                                            
                                            <!-- Arrow -->
                                            <PathIcon Data="M5 12h14M12 5l7 7-7 7" Width="10" Height="10" 
                                                      Foreground="{DynamicResource TextSecondaryBrush}" 
                                                      VerticalAlignment="Center"
                                                      IsVisible="{Binding IsDone}"/>
                                            
                                            <!-- Result Size -->
                                            <TextBlock Text="{Binding ResultSizeDisplay}" FontSize="11" 
                                                       Foreground="{DynamicResource AccentBlueBrush}" 
                                                       VerticalAlignment="Center" TextTrimming="None" TextWrapping="NoWrap"
                                                       IsVisible="{Binding IsDone}"/>
                                        </StackPanel>
                                        
                                        <!-- Status "Selesai" (Bottom Right) -->
                                         <TextBlock Text="Selesai" FontSize="10" FontWeight="SemiBold" 
                                                    Foreground="{DynamicResource AccentBlueBrush}" 
                                                    HorizontalAlignment="Right"
                                                    Margin="0,2,0,0"
                                                    IsVisible="{Binding IsDone}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Overlay: Settings -->
                 <Border Background="#CC000000" IsVisible="{Binding IsSettingsOpen}">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <Border Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="20"
                            Margin="10">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Settings (Network &amp; VPN)" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            
                            <!-- Static Proxy -->
                            <StackPanel Spacing="5">
                                <TextBlock Text="Proxy Server (HTTP/SOCKS5)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding ProxyAddress}" Watermark="http://username:pass@127.0.0.1:8080" FontSize="12" />
                            </StackPanel>
                            
                            <!-- OVPN Section -->
                            <StackPanel Spacing="5" Margin="0,10,0,0">
                                <TextBlock Text="OpenVPN Profile (.ovpn)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Grid ColumnDefinitions="*, Auto, Auto">
                                    <TextBox Grid.Column="0" Text="{Binding OvpnPath}" Watermark="Pilih file .ovpn..." IsReadOnly="True" FontSize="12" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Command="{Binding PickOvpnFileCommand}" Content="Browse" FontSize="12" Padding="12,6" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Command="{Binding OpenVpnBookLinkCommand}" Background="Transparent" ToolTip.Tip="Buka Website VPNBook" Padding="6">
                                        <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" 
                                                  Width="18" Height="18" Foreground="{DynamicResource AccentBlueBrush}"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                            
                            <!-- OVPN Auth -->
                            <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                                <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,5,0">
                                    <TextBlock Text="Username VPN" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding OvpnUsername}" Watermark="vpnbook" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="5" Margin="5,0,0,0">
                                    <TextBlock Text="Password VPN" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding OvpnPassword}" PasswordChar="•" Watermark="password" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- VPN Config Status Indicator -->
                            <TextBlock Text="{Binding OvpnConfigStatus}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding OvpnConfigColor}" 
                                       TextWrapping="Wrap" Margin="0,8,0,0"
                                       IsVisible="{Binding OvpnConfigStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            
                            <!-- VPNBook Password Note -->
                            <Border Background="#1AF59E0B" CornerRadius="6" Padding="10,8" Margin="0,5,0,0"
                                    IsVisible="{Binding IsOvpnConfigured}">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="ℹ️ Catatan VPNBook" FontSize="11" FontWeight="Bold" Foreground="#F59E0B"/>
                                    <TextBlock Text="Password VPNBook diperbarui setiap beberapa hari. Jika proses gagal dengan error autentikasi, kunjungi vpnbook.com untuk mendapatkan password terbaru lalu perbarui di kolom di atas." 
                                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Margin="0,10"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                                <Button Command="{Binding CloseSettingsCommand}" Content="Tutup &amp; Simpan" Background="{DynamicResource AccentBlueBrush}" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    </ScrollViewer>
                </Border>

                <!-- Log View Overlay -->
                <Border IsVisible="{Binding IsLogViewVisible}" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="20" ZIndex="50">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Log Header -->
                        <Grid Grid.Row="0" Margin="15,12,15,0" ColumnDefinitions="Auto, *, Auto">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <PathIcon Data="M20 19V7H4v12h16m0-16a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16M7 10l3 3-3 3m4 0h6" 
                                          Width="14" Height="14" Foreground="{DynamicResource AccentBlueBrush}"/>
                                <TextBlock Text="Terminal Log" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding CloseLogViewCommand}"
                                    Background="Transparent" BorderThickness="0" Padding="6" CornerRadius="4"
                                    ToolTip.Tip="Kembali ke File List">
                                <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                          Width="12" Height="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>
                        <!-- Log Content -->
                        <TextBox Grid.Row="1" Text="{Binding LogOutput}" IsReadOnly="True" 
                                 Background="Transparent" BorderThickness="0" 
                                 FontFamily="Consolas, Menlo, monospace" FontSize="11" 
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Padding="15,10" Margin="0"
                                 CaretBrush="Transparent"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Footer / Controls -->
        <Border Grid.Row="2" Margin="0,10,0,0" Background="{DynamicResource CardBackgroundBrush}" 
                CornerRadius="12" Padding="15,10" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,1,1,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                
                <!-- Left: Utils -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                     <!-- VPN Indicator (Moved Here) -->
                      <Border Background="Transparent" CornerRadius="4" Padding="8,4" ToolTip.Tip="{Binding VpnStatus}" VerticalAlignment="Center">
                          <Panel Width="6" Height="6">
                              <Border CornerRadius="3" Background="#4ade80" IsVisible="{Binding IsVpnActive}"/>
                              <Border CornerRadius="3" Background="#ef4444" IsVisible="{Binding !IsVpnActive}"/>
                          </Panel>
                      </Border>
                      
                      <!-- Settings -->
                      <Button Command="{Binding ShowSettingsCommand}" ToolTip.Tip="Settings" 
                              Background="Transparent" BorderThickness="0" Padding="0"
                              Height="32" Width="32" CornerRadius="4">
                          <!-- IconSettings (Gear) -->
                          <PathIcon Data="{StaticResource IconSettings}" 
                                    Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </Button>

                      <!-- Toggle Log View -->
                      <Button Command="{Binding ToggleLogViewCommand}" 
                              ToolTip.Tip="Terminal Log" 
                              Background="Transparent" BorderThickness="0" Padding="0"
                              Height="32" Width="32" CornerRadius="4">
                          <!-- Terminal Icon -->
                          <PathIcon Data="M20 19V7H4v12h16m0-16a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16M7 10l3 3-3 3m4 0h6" 
                                    Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </Button>
                 </StackPanel>

                <!-- Right: Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    
                    <!-- Retry Failed/Small Files (Moved Here) -->
                     <Button Command="{Binding RetrySmallFilesCommand}" 
                             IsVisible="{Binding IsRetryVisible}"
                             ToolTip.Tip="Retry Failed/Small Files (59b)" 
                             Background="Transparent" BorderThickness="0" Padding="0"
                             Height="32" Width="32" CornerRadius="4">
                        <PathIcon Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" Width="14" Height="14" Foreground="{DynamicResource AccentBlueBrush}"/>
                     </Button>
                     
                    <!-- Clear Button (Moved Here) -->
                     <Button Command="{Binding ClearCommand}" ToolTip.Tip="Clear All (or Selected)" 
                             Background="Transparent" BorderThickness="0" Padding="0"
                             Height="32" Width="32" CornerRadius="4">
                         <!-- IconTrash -->
                         <PathIcon Data="M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6" Width="14" Height="14" Foreground="#EF4444"/>
                     </Button>
                     
                    <!-- Main Actions -->
                    <Button Command="{Binding ProcessRemoveBgCommand}" IsVisible="{Binding !IsProcessing}"
                            Background="{DynamicResource AccentBlueBrush}" Foreground="White" CornerRadius="8" Padding="15,0" BorderThickness="0" Height="32">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <!-- IconLayers (Remove BG) -->
                            <PathIcon Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" Width="14" Height="14"/>
                            <TextBlock Text="Remove BG" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding ProcessUpscaleCommand}" IsVisible="{Binding !IsProcessing}"
                            Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource AccentBlueBrush}" BorderThickness="1"
                            Foreground="{DynamicResource AccentBlueBrush}" CornerRadius="8" Padding="0" Height="32" Width="42"
                            ToolTip.Tip="Upscale">
                        <PathIcon Data="M16 4h-2l-4 4-4-4H4v16h2V8l4 4 4-4v12h2V4z M20 4h-2v16h2V4z" Width="14" Height="14" Foreground="{DynamicResource AccentBlueBrush}"/>
                    </Button>
                    
                    <!-- Processing Controls -->
                     <Button Command="{Binding PauseCommand}" IsVisible="{Binding IsProcessing}"
                            Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1"
                            Foreground="{DynamicResource TextPrimaryBrush}" CornerRadius="8" Padding="15,0" Height="32">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <!-- IconPause / IconPlay -->
                            <PathIcon Data="M6 4h4v16H6z M14 4h4v16h-4z" Width="12" Height="12" IsVisible="{Binding !IsPaused}"/>
                            <PathIcon Data="M5 3 L19 12 L5 21 L5 3 Z" Width="12" Height="12" IsVisible="{Binding IsPaused}"/>
                            
                            <TextBlock Text="JEDA" FontWeight="Bold" VerticalAlignment="Center" IsVisible="{Binding !IsPaused}"/>
                            <TextBlock Text="LANJUTKAN" FontWeight="Bold" VerticalAlignment="Center" IsVisible="{Binding IsPaused}"/>
                        </StackPanel>
                    </Button>
                
                     <Button Command="{Binding StopCommand}" IsVisible="{Binding IsProcessing}"
                            Background="#EF4444" Foreground="White" CornerRadius="8" Padding="15,0" BorderThickness="0" Height="32">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <!-- IconSquare (Stop) -->
                            <PathIcon Data="M3 3h18v18H3z" Width="12" Height="12"/>
                            <TextBlock Text="STOP" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toast Notification (Floating above footer) -->
        <Border Grid.Row="2" Margin="10,0,10,55" IsVisible="{Binding IsToastVisible}" ZIndex="200"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10" Padding="12,8" 
                BorderBrush="{DynamicResource AccentBlueBrush}" BorderThickness="1"
                BoxShadow="0 4 20 0 #40000000"
                HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <TextBlock Grid.Column="0" Text="{Binding ToastIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ToastMessage}" FontSize="12" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Command="{Binding DismissToastCommand}" 
                        Background="Transparent" BorderThickness="0" Padding="4" Margin="8,0,0,0"
                        ToolTip.Tip="Tutup">
                    <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                              Width="8" Height="8" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
