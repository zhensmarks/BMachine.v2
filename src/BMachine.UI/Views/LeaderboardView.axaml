<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BMachine.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="BMachine.UI.Views.LeaderboardView"
             x:DataType="vm:PointLeaderboardViewModel"
             Background="{DynamicResource AppBackgroundBrush}">
    
    <Grid RowDefinitions="Auto, *, Auto" PointerPressed="OnRootPointerPressed" Background="Transparent">
        <!-- Compact Tab Bar (Top) -->
        <Border Grid.Row="0" Margin="20,15,20,10" Background="#10FFFFFF" 
                CornerRadius="6" Padding="3"
                HorizontalAlignment="Center">
            
            <StackPanel Orientation="Horizontal" Spacing="0">
                <!-- HARIAN Tab -->
                <RadioButton Classes="TabButton" Content="HARIAN" IsChecked="{Binding IsHarianSelected}" Command="{Binding SwitchToHarianCommand}"/>
                
                <!-- BULANAN Tab -->
                <RadioButton Classes="TabButton" Content="BULANAN" IsChecked="{Binding IsBulananSelected}" Command="{Binding SwitchToBulananCommand}"/>
            </StackPanel>

            <!-- Style for the compact rounded tabs -->
            <Border.Styles>
                <Style Selector="RadioButton.TabButton">
                    <Setter Property="Template">
                        <ControlTemplate>
                            <Border x:Name="TabBorder" Background="Transparent" CornerRadius="4" Padding="6,5">
                                <TextBlock Text="{TemplateBinding Content}" FontSize="11" 
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter>
                </Style>
                <Style Selector="RadioButton.TabButton:pointerover /template/ Border#TabBorder">
                    <Setter Property="Background" Value="#10FFFFFF"/>
                </Style>
                <Style Selector="RadioButton.TabButton:checked /template/ Border#TabBorder">
                     <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
                </Style>
                <Style Selector="RadioButton.TabButton:checked /template/ TextBlock">
                     <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
                </Style>
            </Border.Styles>
        </Border>

        <!-- List -->
        <ScrollViewer Grid.Row="1" Margin="20,0,20,0">
            <Grid>
                <TextBlock Text="Loading..." HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Foreground="{DynamicResource TextSecondaryBrush}" IsVisible="{Binding IsLoading}"/>
                <ItemsControl ItemsSource="{Binding ActiveItems}" IsVisible="{Binding !IsLoading}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <TextBlock Text="{Binding Rank}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" 
                                               VerticalAlignment="Center" Width="40" TextAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" 
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding FormattedPoints}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentPointsBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Margin="20,8,20,15">
            <Grid ColumnDefinitions="*, Auto">
                <!-- Total Points (Left) -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Total:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FormattedTotalPoints}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentPointsBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Pts" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Refresh FAB (Right) -->
                <Button Grid.Column="1" Command="{Binding LoadDataCommand}" ToolTip.Tip="Refresh"
                        Width="30" Height="30" CornerRadius="15"
                        Background="{DynamicResource AccentBlueBrush}" BorderThickness="0" Padding="0" Cursor="Hand">
                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" 
                              Width="13" Height="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
