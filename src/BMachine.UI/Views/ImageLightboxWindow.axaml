<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="BMachine.UI.Views.ImageLightboxWindow"
        Title="Image Viewer"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        SystemDecorations="None"
        Background="#1A1A1A">

        <Grid Background="Transparent" ClipToBounds="True">
        <Image x:Name="FullScreenImage"
               Stretch="Uniform"
               Margin="20"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               PointerPressed="OnImagePointerPressed"
               PointerMoved="OnImagePointerMoved"
               PointerReleased="OnImagePointerReleased"
               PointerWheelChanged="OnImagePointerWheelChanged">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                    <TranslateTransform X="0" Y="0" />
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <ProgressBar x:Name="LoadingSpinner" IsVisible="False" Width="120" Height="4"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentColorBrush}"
                     Background="#33FFFFFF"/>

        <!-- Floating Action Buttons (Top Right) -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16" ZIndex="10"
                Background="{DynamicResource AppBackgroundBrush}" CornerRadius="8" 
                BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                BoxShadow="0 4 10 0 #40000000">
            <StackPanel Orientation="Horizontal" Margin="4" Spacing="4">
                <!-- Download Button -->
                <Button Width="36" Height="36" CornerRadius="4"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="OnDownloadClick"
                        Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" Content="↓"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        ToolTip.Tip="Download Image">
                </Button>
                <!-- Close Button -->
                <Button Width="36" Height="36" CornerRadius="4"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="OnCloseClick"
                        Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" Content="✕"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        ToolTip.Tip="Close Viewer (Esc / Right Click)">
                </Button>
            </StackPanel>
        </Border>
    </Grid>

</Window>
