<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="BMachine.UI.Views.ImageLightboxWindow"
        Title="Image Viewer"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        SystemDecorations="None"
        Background="#1A1A1A">

        <Grid Background="Transparent">
        <ScrollViewer x:Name="ImageScroller" Margin="0" 
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Image x:Name="FullScreenImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   PointerPressed="OnImagePointerPressed"
                   PointerMoved="OnImagePointerMoved"
                   PointerReleased="OnImagePointerReleased"
                   PointerWheelChanged="OnImagePointerWheelChanged">
                <Image.RenderTransform>
                    <ScaleTransform/>
                </Image.RenderTransform>
            </Image>
        </ScrollViewer>

        <ProgressBar x:Name="LoadingSpinner" IsVisible="False" Width="120" Height="4"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentColorBrush}"
                     Background="#33FFFFFF"/>

        <!-- Floating Action Buttons (Top Right) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Spacing="6" ZIndex="10">
            <!-- Download Button -->
            <Button Width="36" Height="36" CornerRadius="4"
                    Background="#1A1A1A" BorderThickness="1" BorderBrush="#555555"
                    Cursor="Hand" Click="OnDownloadClick"
                    Foreground="White" FontSize="16" FontWeight="Bold" Content="↓"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    ToolTip.Tip="Download Image">
            </Button>
            <!-- Close Button -->
            <Button Width="36" Height="36" CornerRadius="4"
                    Background="#1A1A1A" BorderThickness="1" BorderBrush="#555555"
                    Cursor="Hand" Click="OnCloseClick"
                    Foreground="White" FontSize="18" FontWeight="Bold" Content="✕"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    ToolTip.Tip="Close Viewer (Esc / Right Click)">
            </Button>
        </StackPanel>
    </Grid>

</Window>
