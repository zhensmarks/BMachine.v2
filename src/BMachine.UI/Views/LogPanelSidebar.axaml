<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BMachine.UI.ViewModels"
             xmlns:models="using:BMachine.UI.Models"
             xmlns:converters="using:BMachine.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="290" d:DesignHeight="600"
             x:Class="BMachine.UI.Views.LogPanelSidebar"
             x:DataType="vm:DashboardViewModel">
    <UserControl.Resources>
        <converters:StringToUpperConverter x:Key="StringToUpperConverter"/>
    </UserControl.Resources>

    <UserControl.DataTemplates>
        <TreeDataTemplate DataType="{x:Type models:MasterNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Spacing="4" Background="Transparent" Margin="0,2">
                <PathIcon Data="{StaticResource IconFolder}" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}" IsVisible="False"/>
                <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
        </TreeDataTemplate>
    </UserControl.DataTemplates>

        <Border x:Name="LogPanelDropZone" Background="{DynamicResource TerminalBackgroundBrush}" 
            BorderBrush="#33FFFFFF" BorderThickness="1,0,0,0"
            DragDrop.AllowDrop="True"
            DragDrop.DragOver="OnDragOver"
            DragDrop.Drop="OnDrop"
            PointerPressed="OnRootPointerPressed">
        
        <Grid RowDefinitions="Auto, *, Auto">
            
            <!-- HEADER: Navigation Bar (Row 0) -->
            <Border Grid.Row="0" Padding="8,8,8,4">
                <StackPanel Spacing="6">
                    <!-- Navigation Tab Buttons (same style as dashboard) -->
                    <Border Background="#10FFFFFF" CornerRadius="6" Padding="3">
                        <Grid ColumnDefinitions="*,*,*,*">
                            <Button Grid.Column="0" Classes="panelTab" Click="OnConsoleTabClick"
                                    Tag="{Binding BatchVM.IsConsoleVisible}" ToolTip.Tip="Console">
                                <PathIcon Data="{StaticResource IconTerminal}" Width="14" Height="14"/>
                            </Button>
                            
                            <Button Grid.Column="1" Classes="panelTab" Click="OnMasterTabClick"
                                    Tag="{Binding BatchVM.IsMasterVisible}" ToolTip.Tip="Master">
                                <PathIcon Data="{StaticResource IconGrid}" Width="14" Height="14"/>
                            </Button>
                            
                            <Button Grid.Column="2" Classes="panelTab" Click="OnPhotoshopTabClick"
                                    Tag="{Binding BatchVM.IsPhotoshopVisible}" ToolTip.Tip="Photoshop">
                                <PathIcon Data="{StaticResource IconImageSimple}" Width="14" Height="14"/>
                            </Button>

                            <Button Grid.Column="3" Classes="panelTab" Click="OnDocTabClick"
                                    Tag="{Binding BatchVM.IsDocVisible}" ToolTip.Tip="DOC">
                                <PathIcon Data="{StaticResource IconFileText}" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Search Box (Visible for Master/Photoshop) -->
                    <TextBox Height="28" FontSize="11"
                             Watermark="Search..." Background="#10FFFFFF" BorderThickness="0"
                             CornerRadius="6" VerticalContentAlignment="Center" Padding="10,0"
                             Text="{Binding BatchVM.MasterSearchText, Mode=TwoWay}"
                             IsVisible="{Binding BatchVM.IsSearchVisible}">
                        <TextBox.InnerRightContent>
                            <PathIcon Data="{DynamicResource IconSearch}" Width="10" Height="10" 
                                      Margin="0,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </TextBox.InnerRightContent>
                    </TextBox>
                </StackPanel>
            </Border>
            
            <!-- CONTENT (Row 1) -->
            <Grid Grid.Row="1">
                
                <!-- 1. CONSOLE VIEW -->
                <Grid IsVisible="{Binding BatchVM.IsConsoleVisible}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Progress Bar -->
                    <ProgressBar Grid.Row="0" Height="2" IsVisible="{Binding IsProcessing}"
                                 Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                                 IsIndeterminate="{Binding !IsDeterminateProgress}"
                                 Background="Transparent" Foreground="{DynamicResource PrimaryBrush}"/>

                    <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LogItems}" Margin="10,0,10,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <SelectableTextBlock Text="{Binding Message}" 
                                               Classes.info="{Binding Level, Converter={x:Static vm:LogConverters.IsInfo}}"
                                               Classes.system="{Binding Level, Converter={x:Static vm:LogConverters.IsSystem}}"
                                               Classes.success="{Binding Level, Converter={x:Static vm:LogConverters.IsSuccess}}"
                                               Classes.warning="{Binding Level, Converter={x:Static vm:LogConverters.IsWarning}}"
                                               Classes.error="{Binding Level, Converter={x:Static vm:LogConverters.IsError}}"
                                               Classes.debug="{Binding Level, Converter={x:Static vm:LogConverters.IsDebug}}"
                                               FontSize="11" FontFamily="Consolas, Monospace" 
                                               TextWrapping="Wrap" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- 2. MASTER BROWSER VIEW -->
                <TreeView ItemsSource="{Binding BatchVM.MasterNodes}" 
                          IsVisible="{Binding BatchVM.IsMasterVisible}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent" BorderThickness="0"
                          DoubleTapped="OnMasterNodeDoubleTapped">
                    <TreeView.Styles>
                         <Style Selector="TreeViewItem">
                             <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                         </Style>
                    </TreeView.Styles>
                </TreeView>

                <!-- 3. PHOTOSHOP BROWSER VIEW -->
                <TreeView ItemsSource="{Binding BatchVM.PhotoshopNodes}"
                          IsVisible="{Binding BatchVM.IsPhotoshopVisible}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent" BorderThickness="0"
                          DoubleTapped="OnPhotoshopNodeDoubleTapped">
                    <TreeView.Styles>
                         <Style Selector="TreeViewItem">
                             <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                         </Style>
                    </TreeView.Styles>
                </TreeView>
                
                <!-- 4. DOC VIEW -->
                <Grid IsVisible="{Binding BatchVM.IsDocVisible}" RowDefinitions="Auto, *, Auto" Margin="10,0,10,10">
                    <StackPanel Grid.Row="0" Spacing="6" Margin="0,10,0,10">
                        <TextBlock Text="INSTAN REDAKSI" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                        
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" Text="{Binding BatchVM.SchoolName, Mode=TwoWay}" Watermark="Nama Kelompok / Sekolah" FontSize="12" CornerRadius="4" Padding="6" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Classes="iconBtn" Command="{Binding BatchVM.CopySchoolNameCommand}" ToolTip.Tip="Copy Nama" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource IconCopy}" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" Text="{Binding BatchVM.SchoolAddress, Mode=TwoWay}" Watermark="Alamat Lengkap" FontSize="12" CornerRadius="4" MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap" Padding="6" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Classes="iconBtn" Command="{Binding BatchVM.CopySchoolAddressCommand}" ToolTip.Tip="Copy Alamat" VerticalAlignment="Top" Margin="0,4,0,0">
                                <PathIcon Data="{StaticResource IconCopy}" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="1" Grid.RowSpan="2" ColumnDefinitions="*,10,*">
                        <!-- SLOT 1 -->
                        <Grid Grid.Column="0" RowDefinitions="*, Auto">
                            <Border Grid.Row="0" Background="#0AFFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="6" Padding="4" MinHeight="80"
                                    DragDrop.AllowDrop="True" DragDrop.Drop="OnLogo1Drop" DragDrop.DragOver="OnDragOver" ToolTip.Tip="Logo 1 (Drag &amp; Drop)">
                                 <Grid>
                                     <TextBlock Text="[Logo Utama]\nDrop Di Sini" TextAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding BatchVM.SchoolLogoImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                                     <Image Source="{Binding BatchVM.SchoolLogoImage}" Stretch="Uniform" Margin="4"/>
                                 </Grid>
                            </Border>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" Margin="0,6,0,0">
                                <Button Command="{Binding BatchVM.ResetDocCommand}" CommandParameter="1" ToolTip.Tip="Reset Logo 1" Background="#B54845" BorderThickness="0" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="10" Height="10" Foreground="White"/>
                                </Button>
                                <Button Command="{Binding BatchVM.CopySchoolLogoCommand}" CommandParameter="1" ToolTip.Tip="Copy Logo 1" Background="Transparent" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Width="10" Height="10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Button>
                                <Button Command="{Binding BatchVM.PasteLogoCommand}" CommandParameter="1" ToolTip.Tip="Paste Logo 1" Background="Transparent" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M19,20H5V4H7V7H17V4H19M12,2A1,1 0 0,1 13,3A1,1 0 0,1 12,4A1,1 0 0,1 11,3A1,1 0 0,1 12,2M19,2H14.82C14.4,0.84 13.3,0 12,0C10.7,0 9.6,0.84 9.18,2H5A2,2 0 0,0 3,4V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V4A2,2 0 0,0 19,2Z" Width="10" Height="10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Button>
                                <Button Command="{Binding BatchVM.SendLogoToPhotoshopCommand}" CommandParameter="1" ToolTip.Tip="Kirim ke Photoshop (Logo 1)" Background="Transparent" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Width="10" Height="10" Foreground="{DynamicResource AccentBlueBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- SLOT 2 -->
                        <Grid Grid.Column="2" RowDefinitions="*, Auto">
                            <Border Grid.Row="0" Background="#0AFFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="6" Padding="4" MinHeight="80"
                                    DragDrop.AllowDrop="True" DragDrop.Drop="OnLogo2Drop" DragDrop.DragOver="OnDragOver" ToolTip.Tip="Logo 2 (Drag &amp; Drop)">
                                 <Grid>
                                     <TextBlock Text="[Logo Alternatif]\nDrop Di Sini" TextAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding BatchVM.SchoolLogoImage2, Converter={x:Static ObjectConverters.IsNull}}"/>
                                     <Image Source="{Binding BatchVM.SchoolLogoImage2}" Stretch="Uniform" Margin="4"/>
                                 </Grid>
                            </Border>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" Margin="0,6,0,0">
                                <Button Command="{Binding BatchVM.ResetDocCommand}" CommandParameter="2" ToolTip.Tip="Reset Logo 2" Background="#B54845" BorderThickness="0" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="10" Height="10" Foreground="White"/>
                                </Button>
                                <Button Command="{Binding BatchVM.CopySchoolLogoCommand}" CommandParameter="2" ToolTip.Tip="Copy Logo 2" Background="Transparent" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Width="10" Height="10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Button>
                                <Button Command="{Binding BatchVM.PasteLogoCommand}" CommandParameter="2" ToolTip.Tip="Paste Logo 2" Background="Transparent" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M19,20H5V4H7V7H17V4H19M12,2A1,1 0 0,1 13,3A1,1 0 0,1 12,4A1,1 0 0,1 11,3A1,1 0 0,1 12,2M19,2H14.82C14.4,0.84 13.3,0 12,0C10.7,0 9.6,0.84 9.18,2H5A2,2 0 0,0 3,4V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V4A2,2 0 0,0 19,2Z" Width="10" Height="10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Button>
                                <Button Command="{Binding BatchVM.SendLogoToPhotoshopCommand}" CommandParameter="2" ToolTip.Tip="Kirim ke Photoshop (Logo 2)" Background="Transparent" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="6" CornerRadius="4" Cursor="Hand">
                                    <PathIcon Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Width="10" Height="10" Foreground="{DynamicResource AccentBlueBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
                
            </Grid>
            
            <!-- FOOTER (Row 2) -->
            <Border Grid.Row="2" Background="#08FFFFFF" Padding="10,6" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" IsVisible="{Binding BatchVM.IsStatusVisible}">
                <Grid ColumnDefinitions="*, Auto">
                     <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                         <!-- Status Dot -->
                         <Border Width="6" Height="6" CornerRadius="3" 
                                 Background="{Binding StatusColor}"
                                 VerticalAlignment="Center"
                                 ToolTip.Tip="{Binding ProcessStatusText}"/>

                         <Grid>
                             <!-- Normal Status -->
                             <TextBlock Text="{Binding ProcessStatusText}" 
                                        IsVisible="{Binding !BatchVM.IsMasterVisible}"
                                        Foreground="{DynamicResource TextSecondaryBrush}" 
                                        FontSize="10" 
                                        TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                             
                             <!-- Master Browser Target -->
                             <StackPanel Orientation="Horizontal" IsVisible="{Binding BatchVM.IsMasterVisible}">
                                 <StackPanel.IsVisible>
                                     <MultiBinding Converter="{x:Static BoolConverters.And}">
                                         <Binding Path="BatchVM.IsMasterVisible"/>
                                         <Binding Path="!BatchVM.IsBusy"/>
                                     </MultiBinding>
                                 </StackPanel.IsVisible>
                                 <TextBlock Text="Copy to " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"/>
                                 <TextBlock Text="{Binding BatchVM.MasterBrowserTargetName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                             </StackPanel>
 
                             <!-- BUSY INDICATOR -->
                             <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding BatchVM.IsBusy}">
                                 <ProgressBar IsIndeterminate="True" Width="20" Height="4" VerticalAlignment="Center" Foreground="{DynamicResource AccentBlueBrush}"/>
                                 <TextBlock Text="{Binding BatchVM.BusyMessage}" Foreground="{DynamicResource AccentBlueBrush}" FontSize="10" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                             </StackPanel>
                         </Grid>
                     </StackPanel>
                     
                     <!-- Actions -->
                     <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                         <Button Classes="iconBtn" Command="{Binding StopProcessCommand}" IsVisible="{Binding IsProcessing}" ToolTip.Tip="Stop">
                             <PathIcon Data="{StaticResource IconSquare}" Width="11" Height="11" Foreground="#ef4444"/>
                         </Button>
                         <Button Classes="iconBtn" Command="{Binding CopyAllLogsCommand}" IsVisible="{Binding BatchVM.IsConsoleVisible}" ToolTip.Tip="Copy Log">
                             <PathIcon Data="{StaticResource IconCopy}" Width="11" Height="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         </Button>
                         <Button Classes="iconBtn" Command="{Binding ClearLogCommand}" IsVisible="{Binding BatchVM.IsConsoleVisible}" ToolTip.Tip="Clear Log">
                             <PathIcon Data="{StaticResource IconTrash}" Width="11" Height="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         </Button>
                         <Button Classes="iconBtn" Command="{Binding BatchVM.RefreshMasterCommand}" IsVisible="{Binding BatchVM.IsMasterVisible}" ToolTip.Tip="Refresh">
                             <PathIcon Data="{StaticResource IconRefresh}" Width="11" Height="11"/>
                         </Button>
                     </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>

    <UserControl.Styles>
        
        <!-- Panel Tab Button (matches dashboard nav style) -->
        <Style Selector="Button.panelTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.panelTab /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.panelTab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#15FFFFFF"/>
        </Style>
        <!-- Active state via Tag=True -->
        <Style Selector="Button.panelTab[Tag=True]">
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.panelTab[Tag=True] /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
        </Style>
        
        <!-- Icon Button -->
        <Style Selector="Button.iconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter">
             <Setter Property="Background" Value="#15FFFFFF"/>
        </Style>
        
        <!-- Console TextBox -->
        <Style Selector="TextBox.console">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TextBox.console:focus /template/ Border">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.console:pointerover /template/ Border">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.console:focus-within /template/ Border">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Log Color Styles -->
        <Style Selector="SelectableTextBlock.info"> <Setter Property="Foreground" Value="{DynamicResource TerminalInfoBrush}"/> </Style>
        <Style Selector="SelectableTextBlock.system"> <Setter Property="Foreground" Value="{DynamicResource TerminalSystemBrush}"/> </Style>
        <Style Selector="SelectableTextBlock.success"> <Setter Property="Foreground" Value="{DynamicResource TerminalSuccessBrush}"/> </Style>
        <Style Selector="SelectableTextBlock.warning"> <Setter Property="Foreground" Value="{DynamicResource TerminalWarningBrush}"/> </Style>
        <Style Selector="SelectableTextBlock.error"> <Setter Property="Foreground" Value="{DynamicResource TerminalErrorBrush}"/> </Style>
        <Style Selector="SelectableTextBlock.debug"> <Setter Property="Foreground" Value="{DynamicResource TerminalDebugBrush}"/> </Style>

    </UserControl.Styles>
</UserControl>
